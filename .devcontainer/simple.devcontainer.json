{
  "name": "Streamlit Viewer",
  "dockerComposeFile": "../docker-compose.simple.yml",
  "service": "streamlit",
  "workspaceFolder": "/app",
  "shutdownAction": "none",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/brixels/bin/python"
      }
    }
  }
}
